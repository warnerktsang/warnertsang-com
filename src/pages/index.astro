---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Warner Tsang">
	<main class="page-shell">
		<header class="site-header">
			<a class="site-name" href="/" aria-label="Warner Tsang home">Warner Tsang</a>
		</header>

		<section class="project-section" aria-labelledby="projects-heading">
			<div class="section-heading">
				<h1 id="projects-heading">Projects</h1>
				<p>coming soon</p>
			</div>
		</section>
	</main>
</Layout>

<style>
	.page-shell {
		width: min(1120px, calc(100% - 32px));
		margin: 0 auto;
		padding: 32px 0 56px;
	}

	.site-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 6px 0 64px;
	}

	.site-name {
		font-size: 15px;
		font-weight: 650;
		text-decoration: none;
	}

	.project-section {
		display: grid;
		gap: 22px;
	}

	.section-heading {
		display: flex;
		align-items: end;
		justify-content: space-between;
		gap: 16px;
		border-bottom: 1px solid #d9d6cd;
		padding-bottom: 14px;
	}

	h1,
	h2,
	p {
		margin: 0;
	}

	h1 {
		font-size: clamp(38px, 7vw, 82px);
		line-height: 0.95;
		font-weight: 720;
		letter-spacing: 0;
	}

	.section-heading p {
		color: #666156;
		font-size: 14px;
		white-space: nowrap;
	}

	@media (max-width: 640px) {
		.page-shell {
			width: min(100% - 24px, 1120px);
			padding-top: 22px;
		}

		.site-header {
			padding-bottom: 44px;
		}

		.section-heading {
			align-items: start;
			flex-direction: column;
		}
	}
</style>
